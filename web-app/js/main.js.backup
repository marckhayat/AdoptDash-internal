function handleFileUpload(event) {
  var file = event.target.files[0];
  if (!file) return;

  var ext = file.name.split(".").pop().toLowerCase();
  var sizeMB = file.size / (1024 * 1024);

  if (ext !== "csv" && sizeMB > 20) {
    var msg =
      "This Excel file is " + sizeMB.toFixed(0) + " MB, which is too large to load in the browser.\n\n" +
      "Please export your Workspan report as CSV instead:\n" +
      "  1. In Workspan, run report 19849 (Partners) or 21766 (Distributors)\n" +
      "  2. Click Export → CSV\n" +
      "  3. Upload the .csv file here\n\n" +
      "CSV files of any size work perfectly — there is no size limit.";
    alert(msg);
    event.target.value = "";
    return;
  }

  showLoader("Reading file — this may take a moment for large files…");

  if (ext === "csv") {
    handleCSV(file);
  } else {
    handleXLSX(file);
  }
}

function handleInternalFetch() {
  var region  = document.getElementById("internal-region").value;
  var beGeoId = document.getElementById("internal-begeo").value.trim();
  var week    = document.getElementById("internal-week").value.trim().toUpperCase();

  if (!region) { alert("Please select a region."); return; }
  if (!week)   { alert("Please enter a week (e.g. " + getCurrentISOWeekStr() + ")."); return; }

  var url = SHAREPOINT_URLS[region] + week + ".csv";
  window.INTERNAL_BEGEO_FILTER = beGeoId;
  window.INTERNAL_LABEL = region + " · Week " + week + (beGeoId ? " · BE GEO ID " + beGeoId : " · All partners");

  var opened = window.open(url, "_blank");
  
  if (!opened) {
    var msg = 
      "Pop-up blocked. Please allow pop-ups or open this link manually:\n\n" + url + 
      "\n\nAfter downloading, upload the CSV file using the 'Partner / Distributor' option above.";
    alert(msg);
    return;
  }

  setTimeout(function() {
    var msg = 
      "SharePoint opened in a new tab.\n\n" +
      "1. Download the CSV file from SharePoint\n" +
      "2. Upload it using the 'Partner / Distributor' file upload above" +
      (beGeoId ? "\n\n(The filter for BE GEO ID " + beGeoId + " will be applied automatically after upload.)" : "");
    alert(msg);
  }, 500);
}

function handleCSV(file) {
  Papa.parse(file, {
    header: true,
    skipEmptyLines: true,
    dynamicTyping: false,
    worker: false,
    step: null,
    complete: function(results) {
      if (!results.data || results.data.length === 0) {
        restoreUploadSection();
        alert("The CSV file appears to be empty or has no data rows.");
        return;
      }
      var data = results.data;
      var filename = file.name;
      
      if (window.INTERNAL_BEGEO_FILTER) {
        var beGeoId = window.INTERNAL_BEGEO_FILTER;
        data = data.filter(function (row) {
          return row["BE GEO ID"] && String(row["BE GEO ID"]).trim() === beGeoId;
        });
        if (data.length === 0) {
          restoreUploadSection();
          alert('No records found for BE GEO ID "' + beGeoId + '".\n\nCheck the ID and try again.');
          window.INTERNAL_BEGEO_FILTER = null;
          window.INTERNAL_LABEL = null;
          return;
        }
        filename = window.INTERNAL_LABEL || filename;
        window.INTERNAL_BEGEO_FILTER = null;
        window.INTERNAL_LABEL = null;
      }
      
      updateLoaderMsg("Processing " + data.length.toLocaleString() + " rows…");
      setTimeout(function() {
        try {
          APP_DATA = transformData(data);
          finishLoad(filename, APP_DATA.length, false);
        } catch(err) {
          restoreUploadSection();
          console.error(err);
          alert("Error processing data: " + err.message);
        }
      }, 50);
    },
    error: function(err) {
      restoreUploadSection();
      alert("Error reading CSV: " + err.message);
    }
  });
}

function handleXLSX(file) {
  var reader = new FileReader();
  reader.onload = function (e) {
    var buffer = e.target.result;
    var workerSupported = (typeof Worker !== 'undefined');

    if (workerSupported) {
      try {
        var workerSrc = 'js/xlsx-worker.js';
        var worker = new Worker(workerSrc);

        worker.onmessage = function (ev) {
          var msg = ev.data;
          if (msg.type === 'progress') {
            updateLoaderMsg(msg.msg);
          } else if (msg.type === 'done') {
            worker.terminate();
            parseCSVAndFinish(msg.csv, file.name, msg.headerIdx > 0);
          } else if (msg.type === 'error') {
            worker.terminate();
            restoreUploadSection();
            alert('Error reading Excel file:\n' + msg.msg);
          }
        };

        worker.onerror = function (err) {
          worker.terminate();
          console.warn('Worker failed, falling back to main thread:', err.message);
          handleXLSXMainThread(buffer, file.name);
        };

        worker.postMessage(buffer, [buffer]);
        return;
      } catch (workerErr) {
        console.warn('Could not start worker, falling back to main thread:', workerErr.message);
      }
    }

    handleXLSXMainThread(buffer, file.name);
  };
  reader.readAsArrayBuffer(file);
}

